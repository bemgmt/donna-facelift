# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-10-01

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
DEFAULT_VOICE_ID=XcXEQzuLXRU9RcfWzEJt
VOICE_MODEL=eleven_multilingual_v2

# Gmail Configuration
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Google OAuth (Next.js Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/oauth/callback

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=DONNA

# System Configuration
DOMAIN_NAME=localhost
PRODUCTION_DOMAIN=your-production-domain.com
ENVIRONMENT=development
DEBUG_MODE=true
NEXT_PUBLIC_APP_VERSION=1.0.0
APP_VERSION=1.0.0
NEXT_PUBLIC_API_BASE=http://localhost/donna
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001/realtime

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Security / CORS
ALLOWED_ORIGINS=http://localhost:3000

# DONNA Drive — Interactive Demo
# Set to "true" to enable the /drive demo experience
DONNA_DRIVE_ENABLED=false
NEXT_PUBLIC_DONNA_DRIVE_ENABLED=false
# Facilitator secret for seeding and event injection (server-side only)
DONNA_DRIVE_FACILITATOR_SECRET=donna-drive-dev

# Donna-hosted MCP JSON-RPC bridge
DONNA_MCP_BASE_URL=https://app.bemdonna.com
DONNA_MCP_TOKEN=
# Optional: override the tenant tool selected after tools/list.
DONNA_MCP_INVESTOR_TOOL=search_base_knowledge
DONNA_MCP_DRIVE_TOOL=
DONNA_MCP_SEARCH_LIMIT=5
